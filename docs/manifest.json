{
  "name": "日曆記事本 V1.0",
  "short_name": "月曆 V1.0",
  "description": "日曆記事本 - 記錄每一天的美好時刻",
  "lang": "zh-Hant",
  "id": "./?app=calendar-diary-v1",
  "start_url": "./index.html?app=calendar-diary-v1",
