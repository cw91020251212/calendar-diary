{
  "name": "日曆記事本",
  "short_name": "日曆記事本",
  "description": "日曆記事本（可安裝成 Edge Web App）",
  "lang": "zh-Hant",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0b1220",
  "theme_color": "#22c55e",
  "icons": [
    {"src": "./icon-192.png", "sizes": "192x192", "type": "image/png"},
    {"src": "./icon-512.png", "sizes": "512x512", "type": "image/png"}
  ],
  "share_target": {
    "action": "./receive.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {"name": "files", "accept": ["*/*"]}
      ]
    }
  }
}
